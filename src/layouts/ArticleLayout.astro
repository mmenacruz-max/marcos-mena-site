---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  backHref: string;
  backLabel: string;
}

const { title, description, backHref, backLabel } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    <a
      href={backHref}
      class="mb-8 inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-accent-hover"
    >
      ← {backLabel}
    </a>
    <slot name="header" />
    <div class="prose mt-8">
      <slot />
    </div>
  </article>
</BaseLayout>
