---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, defaultMeta } from '../data/site';
import { experience, education, skillGroups, resumeHeader } from '../data/resume';
---

<BaseLayout title="Resume" description={`Resume of ${site.name}. ${defaultMeta.description}`}>
  <section class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    <header class="flex flex-col gap-4 border-b border-border pb-8 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 class="font-display text-3xl font-bold text-text md:text-4xl">Resume</h1>
        <p class="mt-2 text-text-muted">{resumeHeader.contact}</p>
        <p class="mt-1 text-sm text-text-muted">
          <a href={`mailto:${site.email}`} class="text-accent hover:text-accent-hover">{site.email}</a>
          {' · '}
          <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover">
            LinkedIn
          </a>
        </p>
      </div>
      <a href="/resume.pdf" download class="btn-primary shrink-0">
        Download PDF
      </a>
    </header>

    <section class="mt-10">
      <h2 class="font-display text-xl font-semibold text-text border-b border-border pb-2">
        Experience
      </h2>
      {
        experience.map((role) => (
          <article class="mt-8">
            <header>
              <h3 class="font-display text-lg font-semibold text-text">{role.title}</h3>
              <p class="text-accent font-medium">
                {role.company} · {role.location}
              </p>
              <p class="text-sm text-text-muted">{role.period}</p>
            </header>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-text-muted leading-relaxed">
              {role.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>

    <section class="mt-12">
      <h2 class="font-display text-xl font-semibold text-text border-b border-border pb-2">
        Education
      </h2>
      <article class="mt-6">
        <h3 class="font-display text-lg font-semibold text-text">{education.school}</h3>
        <p class="text-text-muted">{education.degree}</p>
        <p class="text-sm text-text-muted">{education.period}</p>
        <p class="mt-2 text-sm text-text-muted">
          <span class="font-medium text-text">Relevant Coursework:</span> {education.coursework}
        </p>
      </article>
    </section>

    <section class="mt-12">
      <h2 class="font-display text-xl font-semibold text-text border-b border-border pb-2">
        Skills
      </h2>
      <ul class="mt-6 grid gap-6 sm:grid-cols-2 list-none p-0 m-0">
        {
          skillGroups.map((group) => (
            <li>
              <h3 class="font-medium text-text">{group.category}</h3>
              <p class="mt-2 text-sm text-text-muted">{group.items.join(' · ')}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </section>
</BaseLayout>
