---
import { site } from '../data/site';
---

<footer class="mt-auto border-t border-border bg-surface">
  <section class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-10 md:flex-row md:items-center md:justify-between">
    <p class="font-display text-sm font-semibold text-text">{site.name}</p>
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-text-muted list-none p-0 m-0">
      <li><a href={`mailto:${site.email}`} class="hover:text-accent">{site.email}</a></li>
      <li><a href={`tel:${site.phone.replace(/\D/g, '')}`} class="hover:text-accent">{site.phone}</a></li>
      <li>
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
          LinkedIn
        </a>
      </li>
      <li>{site.location}</li>
    </ul>
  </section>
</footer>
