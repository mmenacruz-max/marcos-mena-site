---
import { site } from '../data/site';
---

<section class="mx-auto max-w-5xl px-6 py-16 md:py-24">
  <section class="flex flex-col gap-10 md:flex-row md:items-center md:gap-16">
    <img
      src={site.headshot}
      alt={`Portrait of ${site.name}`}
      width="280"
      height="280"
      class="h-44 w-44 shrink-0 rounded-2xl border border-border bg-surface object-cover sm:h-52 sm:w-52 md:h-64 md:w-64"
      loading="eager"
      decoding="async"
    />
    <section>
      <h1 class="font-display text-4xl font-bold tracking-tight text-text md:text-5xl">
        {site.name}
      </h1>
      <p class="mt-3 text-xl text-accent font-medium">{site.title}</p>
      <p class="mt-4 max-w-xl text-lg text-text-muted leading-relaxed">{site.tagline}</p>
      <p class="mt-6 flex flex-wrap gap-4">
        <a href="/resume" class="btn-primary">View Resume</a>
        <a href="/projects" class="btn-secondary">View Projects</a>
        <a href={`mailto:${site.email}`} class="btn-secondary">Email me</a>
      </p>
    </section>
  </section>
</section>
