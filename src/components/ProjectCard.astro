---
interface Props {
  slug: string;
  title: string;
  summary: string;
  tags: string[];
  outcome: string;
  website?: string;
}

const { slug, title, summary, tags, outcome, website } = Astro.props;
---

<article class="card flex flex-col h-full">
  <h3 class="font-display text-xl font-semibold text-text">
    <a href={`/projects/${slug}`} class="hover:text-accent">{title}</a>
  </h3>
  <p class="mt-2 flex-1 text-sm text-text-muted leading-relaxed">{summary}</p>
  <p class="mt-3 text-sm font-medium text-accent">{outcome}</p>
  <ul class="mt-4 flex flex-wrap gap-2 list-none p-0 m-0">
    {tags.map((tag) => (
      <li><span class="tag">{tag}</span></li>
    ))}
  </ul>
  <p class="mt-4 flex flex-wrap gap-4">
    <a
      href={`/projects/${slug}`}
      class="text-sm font-medium text-accent hover:text-accent-hover"
    >
      Read case study →
    </a>
    {
      website && (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-accent hover:text-accent-hover"
        >
          oleosandcanvas.com ↗
        </a>
      )
    }
  </p>
</article>
