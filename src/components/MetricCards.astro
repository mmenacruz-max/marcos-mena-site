---
import { metrics } from '../data/site';
---

<section class="mx-auto max-w-5xl px-6 pb-16">
  <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 list-none p-0 m-0">
    {
      metrics.map((m) => (
        <li class="metric-card">
          <p class="font-display text-2xl font-bold text-accent">{m.value}</p>
          <p class="mt-1 font-medium text-text">{m.label}</p>
          <p class="mt-1 text-sm text-text-muted">{m.detail}</p>
        </li>
      ))
    }
  </ul>
</section>
